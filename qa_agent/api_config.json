{
  "base_url": "https://reqres.in",
  "endpoints": {
    "get_user": {
      "method": "GET",
      "path": "/api/users/{id}"
    },
    "list_users": {
      "method": "GET",
      "path": "/api/users?page={page}"
    },
    "create_user": {
      "method": "POST",
      "path": "/api/users"
    },
    "update_user": {
      "method": "PUT",
      "path": "/api/users/{id}"
    },
    "patch_user": {
      "method": "PATCH",
      "path": "/api/users/{id}"
    },
    "delete_user": {
      "method": "DELETE",
      "path": "/api/users/{id}"
    }
  }
}